{
    "name": "maestrodimateo/simple-consul",
    "description": "A simple, elegant Laravel wrapper for HashiCorp Consul",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3 || ^8.4",
        "friendsofphp/consul-php-sdk": "^5.3",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "Maestrodimateo\\SimpleConsul\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Maestrodimateo\\SimpleConsul\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maestrodimateo\\SimpleConsul\\SimpleConsulServiceProvider"
            ],
            "aliases": {
                "Consul": "Maestrodimateo\\SimpleConsul\\Facades\\Consul"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
